						{
							"name": "apiLogin",
							"event": [
								{
									"listen": "test",
									"script": {
										"exec": [
											"// Captura el token JWT de la cabecera 'Authorization' y lo guarda como variable de colección\r",
											"let token = pm.response.headers.get(\"Authorization\");\r",
											"\r",
											"if (token) {\r",
											"    // Elimina el prefijo 'Bearer ' si existe\r",
											"    if (token.startsWith(\"Bearer \")) {\r",
											"        token = token.substring(7);\r",
											"    }\r",
											"    pm.collectionVariables.set(\"jwt\", token);\r",
											"    console.log(\"Token JWT guardado en variable 'jwt':\", token);\r",
											"} else {\r",
											"    console.warn(\"No se encontró la cabecera Authorization en la respuesta.\");\r",
											"}\r",
											""
										],
										"type": "text/javascript",
										"packages": {}
									}
